# Supabase — get these from your Supabase project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# A secret you choose yourself. The Android app must send this exact value
# in an "x-api-key" header when uploading a ride to /api/rides. Generate
# any long random string, e.g.: openssl rand -hex 32
RIDE_UPLOAD_API_KEY=

# Set to the real deployed domain once you have one (used only for
# metadata/OG tags if you extend those later — not required to run).
NEXT_PUBLIC_SITE_URL=https://wattsoneuc.com
